# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ─── Database ─────────────────────────────────────────────
# Use a dedicated database name, e.g. ecocycle (path before ?)
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/ecocycle?retryWrites=true&w=majority

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ─────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ─── Classification ───────────────────────────────────────
# Options: gemini | yolo | mock
CLASSIFIER=yolo
GEMINI_API_KEY=your_gemini_api_key_here
# Model id for @google/generative-ai (examples: gemini-2.0-flash, gemini-1.5-flash, gemini-flash-latest)
GEMINI_MODEL=gemini-2.0-flash

# Only needed if CLASSIFIER=yolo
YOLO_API_URL=https://eco-cycle-production.up.railway.app/predict
# Optional: axios timeout (ms) for cold starts / slow CPU inference
# YOLO_HTTP_TIMEOUT_MS=30000

# ─── Tuning (optional overrides) ──────────────────────────
CONFIDENCE_THRESHOLD=0.72
FRAUD_WINDOW_MINUTES=60
